# Ops-Agent example configuration
# Copy to .ops-agent.yaml or ~/.config/ops-agent/config.yaml

# Issue 入待办规则（由 GitHub webhook 触发，非轮询单仓库）
issue_watch:
  enabled: true
  labels: ["ops", "needs-triage"]   # OR：命中任一 label；空列表=不过滤 label
  require_unassigned: true
  todo:
    max_items: 50

# GitHub 仓库 Webhook（/webhook 菜单可配置，每项有说明）
webhook:
  enabled: true
  listen: "127.0.0.1:8765"       # 本机 host:port，内嵌 smee 转发目标
  path: "/webhooks/github"         # 与 listen 组成完整本地 URL
  secret: ""                       # 与 GitHub Webhook Secret 一致；留空=本地调试跳过校验
  public_url: "https://smee.io/YOUR-CHANNEL-ID"  # GitHub Payload URL（不要加 /webhook）
  tunnel:
    smee:
      enabled: true                # 内嵌 smee 客户端，无需单独运行 smee-client

# 接入步骤:
#   1. https://smee.io 生成频道 → 填入 public_url
#   2. GitHub Organization Webhooks → Payload URL = public_url
#      Events: Issues + Issue comments + Pull requests + Pushes + Releases（验收）
#   3. make run（或 ./ops-agent）

issue_automation:
  mode: semi
  auto_analyze: true
  confirm_before_reply: true
  auto_reply:
    only_labels: []
    max_comments_per_hour: 10
    comment_footer: |
      ---
      _Posted by Ops-Agent (auto)_
  # Issue 确认后重构并开 PR — 在 TUI /mode 菜单配置
  refactor_pr:
    enabled: false
    trigger: manual
    branch_prefix: ops-agent/issue-
    test_commands: []
    max_steps: 0
  notify_on_ready: false
  notify_on_posted: false

notify:
  on_failure: true
  channels:
    slack:
      enabled: false
      webhook_url: ${SLACK_WEBHOOK}
    feishu:
      enabled: false
      webhook_url: ${FEISHU_WEBHOOK}
    dingtalk:
      enabled: false
      webhook_url: ${DINGTALK_WEBHOOK}

ai:
  provider: openai-compatible
  base_url: http://127.0.0.1:8080/v1
  model: qwen3-coder
  api_key: local
  investigator:
    max_steps: 12
    max_issue_comments: 5   # 分析时纳入最近 N 条用户评论（排除 Agent 自动回复）
    max_tool_errors: 3
    read_file_max_lines: 200
    read_file_max_bytes: 16384
    search_max_hits: 30
    total_context_bytes: 96000
    web_search_enabled: true
    web_fetch_enabled: true
    fetch_max_bytes: 48000
    fetch_timeout_sec: 20
    web_search_max_results: 8
  repo_context:
    enabled: true
  rag:
    enabled: true
    # knowledge_dir: ""   # 默认 ~/.local/share/ops-agent/knowledge
    reindex_on_analyze: true
    default_standard: arduino-library
    inject_top_k: 4
    search_top_k: 8
    chunk_lines: 48
    chunk_overlap_lines: 8
    max_file_bytes: 512000
    max_chunks_total: 8000

# 知识库目录结构（首次分析时自动创建）:
#   knowledge/standards/   仓库格式 YAML（repo_validate 使用）
#   knowledge/datasheets/  芯片数据手册 Markdown/文本
#   knowledge/repos/       按 owner/repo/ 的补充说明

proxy:
  enabled: false
  https_proxy: http://127.0.0.1:7890
  http_proxy: ""
  no_proxy: "127.0.0.1,localhost"

lib_test:
  enabled: true
  standard: arduino-library
  min_demos: 1
  demo_dir: examples
  auto_run: true
  # auto_run: false   # 手动模式：仅入队，选中后 Enter 验收（/accept 可切换）
  on_push: true
  on_release: true
  on_repo_created: false
  max_queue_items: 30
  # workspace_dir: ""  # 默认 ~/.local/share/ops-agent/lib-test/workspaces

ci:
  pr_check_on_events:
    - pull_request
