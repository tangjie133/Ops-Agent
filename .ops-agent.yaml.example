# Ops-Agent example configuration
# Copy to .ops-agent.yaml or ~/.config/ops-agent/config.yaml

# Issue 入待办规则（由 GitHub webhook 触发，非轮询单仓库）
issue_watch:
  enabled: true
  labels: ["ops", "needs-triage"]   # OR：命中任一 label；空列表=不过滤 label
  require_unassigned: true
  todo:
    max_items: 50

# GitHub App / 仓库 Webhook 接收（与 GitHub 侧配置的 secret 一致）
webhook:
  enabled: true
  listen: "127.0.0.1:8765"
  path: "/webhooks/github"
  secret: ${GITHUB_WEBHOOK_SECRET}
  public_url: ""   # GitHub App Webhook URL（smee/ngrok 公网地址）

issue_automation:
  mode: semi
  auto_analyze: true
  confirm_before_reply: true
  auto_reply:
    only_labels: []
    max_comments_per_hour: 10
    comment_footer: |
      ---
      _Posted by Ops-Agent (auto)_
  notify_on_ready: false
  notify_on_posted: false

notify:
  on_failure: true
  channels:
    slack:
      enabled: false
      webhook_url: ${SLACK_WEBHOOK}
    feishu:
      enabled: false
      webhook_url: ${FEISHU_WEBHOOK}
    dingtalk:
      enabled: false
      webhook_url: ${DINGTALK_WEBHOOK}

ai:
  provider: openai-compatible
  base_url: http://127.0.0.1:8080/v1
  model: qwen2.5-coder
  api_key: local

ci:
  pr_check_on_events:
    - pull_request
